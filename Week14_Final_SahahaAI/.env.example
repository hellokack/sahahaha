# ===== Supabase =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
# 관리자 작업(크롤링 갱신, TTL 정리)용. RLS 우회 가능하므로 외부 노출 금지
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ===== Groq LLM =====
GROQ_API_KEY=your_groq_api_key

# ===== Flask =====
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
# 필수: 비워두면 서버가 시작되지 않음 (세션 위조 방지)
SECRET_KEY=replace_with_random_string_at_least_32_chars

# ===== 관리자 API 인증 =====
# /api/stats 등 관리자용 엔드포인트 인증 키
ADMIN_API_KEY=replace_with_random_admin_key

# ===== CORS =====
# 위젯 임베딩 허용 출처 (쉼표 구분)
CORS_ALLOWED_ORIGINS=https://www.saha.go.kr,https://saha.go.kr

# ===== Rate Limiting =====
RATE_LIMIT_CHAT=10 per minute

# ===== 대화 이력 보관 기간 =====
CONVERSATION_TTL_DAYS=30
